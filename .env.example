# ========================================
# StudentAssist — Environment Variables
# ========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google OAuth (Calendar + optional Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# GitHub
GITHUB_TOKEN=ghp_...

# Weather (OpenWeatherMap)
OPENWEATHERMAP_API_KEY=

# App
PORT=3000
DB_PATH=./data/student-assist.db
NODE_ENV=development

# Mock mode (set to true to use demo data for all services, no API keys needed)
MOCK_MODE=false
